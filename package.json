{
  "name": "yosan-flow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run --passWithNoTests tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "build": "vite build",
    "cf:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:reset:local": "rm -rf .wrangler/state/v3/d1 .tmp-wrangler-state/v3/d1 && wrangler d1 migrations apply DB --local",
    "cf:migrate:preview": "wrangler d1 migrations apply DB --env preview --remote",
    "cf:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "bits-ui": "^2.18.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "lucide-svelte": "^1.0.1"
  }
}
