{
  "name": "yosan-flow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run --passWithNoTests tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage tests/unit tests/integration",
    "test:e2e": "playwright test",
    "build": "vite build",
    "cf:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf:reset:local": "rm -rf .wrangler/state/v3/d1 .tmp-wrangler-state/v3/d1 && wrangler d1 migrations apply DB --local",
    "cf:migrate:preview": "wrangler d1 migrations apply DB --env preview --remote",
    "cf:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "bits-ui": "^2.18.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.22.0",
    "@lucide/svelte": "^1.25.0"
  }
}
